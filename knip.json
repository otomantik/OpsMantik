{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/**/{page,layout,route,default,error,loading,not-found,template}.{ts,tsx}",
    "components/dashboard/widgets/breakdown-widgets.tsx",
    "components/dashboard/widgets/pulse-projection-widgets.tsx",
    "components/dashboard/widgets/traffic-source-breakdown.tsx",
    "tests/**/*.test.ts",
    "tests/*.test.ts",
    "tests/**/*.spec.ts"
  ],
  "project": ["**/*.{ts,tsx}"],
  "ignore": [
    "adsmantik-engine/**",
    "scripts/**",
    "analyze-sessions.ts",
    "check-ads-quality.ts",
    "check-schema.ts",
    "heal-data.ts",
    "search-schema.ts",
    "verify-stitching.ts",
    "scratch/**",
    "supabase/functions/**",
    "lib/domain/mizan-mantik/**",
    "lib/domain/funnel-kernel/index.ts",
    "lib/domain/pipeline-fsm.ts",
    "lib/dic/index.ts",
    "lib/ingest/worker-kernel.ts",
    "lib/oci/convergence-gates.ts",
    "lib/oci/conversion-ssot.ts",
    "lib/oci/export-gate.ts",
    "lib/oci/index.ts",
    "lib/oci/processing-recovery-policy.ts",
    "lib/oci/pulse-recovery-worker.ts",
    "lib/oci/stable-order-id.ts",
    "lib/security/hmac-verification.ts",
    "lib/services/audit-logger.ts",
    "lib/shared/time-utils.ts",
    "lib/oci/export/auth.ts",
    "lib/oci/google-ads-export/signal-normalizers.ts",
    "lib/providers/google-ads-api/conversion-upload-adapter.ts",
    "components/feature-guard.tsx",
    "components/upsell-ui.tsx",
    "components/dashboard/breakdown-widget.tsx",
    "components/dashboard/dashboard-header-v2.tsx",
    "components/dashboard/date-range-picker.tsx",
    "components/dashboard/health-indicator.tsx",
    "components/dashboard/intent-card-simple.tsx",
    "components/dashboard/intent-status-badge.tsx",
    "components/dashboard/intent-type-badge.tsx",
    "components/dashboard/kpi-cards-v2.tsx",
    "components/dashboard/realtime-pulse.tsx",
    "components/dashboard/session-group.tsx",
    "components/dashboard/timeline-chart.tsx",
    "components/dashboard/cards/intent-card.tsx",
    "components/dashboard/session-group/session-card-expanded.tsx",
    "components/dashboard/session-group/session-card-header.tsx",
    "components/dashboard/session-group/visitor-history-drawer.tsx",
    "components/dashboard/widgets/ad-spend-widget.tsx",
    "components/ui/badge.tsx",
    "lib/hooks/use-breakdown-data.ts",
    "lib/hooks/use-dashboard-stats.ts",
    "lib/hooks/use-timeline-data.ts",
    "lib/hooks/use-visitor-history.ts"
  ],
  "ignoreBinaries": ["k6", "wrangler"],
  "ignoreDependencies": ["tailwindcss"],
  "ignoreIssues": {
    "postcss.config.mjs": ["unlisted"]
  },
  "exclude": ["types", "exports", "enumMembers", "classMembers", "duplicates"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  }
}
