# Playwright E2E (dashboard-watchtower.spec.ts)
# Set E2E_SITE_ID to run E2E tests; otherwise all 16 tests are skipped.
# E2E_SITE_ID=your-site-uuid-or-public-id
# PLAYWRIGHT_SITE_ID=your-site-uuid-or-public-id
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# E2E_SITE_PUBLIC_ID=32-char-public-id
# E2E_CALL_EVENT_SECRET=site-call-event-secret
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=service_role_key

# Conversation Layer E2E / smoke (default base: https://console.opsmantik.com)
# SMOKE_BASE_URL=https://console.opsmantik.com
# SMOKE_SITE_ID=your-site-public-id
# CALL_EVENT_SECRET=site-call-event-secret (for prod-gdpr-call-event.mjs)

# Optional: base URL for smoke scripts (default http://localhost:3000)
# PROOF_URL=http://localhost:3000
# Auth state path for Playwright screenshot scripts (default: tmp/smoke-evidence/auth/auth-state.json)
# PROOF_STORAGE_STATE=tmp/smoke-evidence/auth/auth-state.json
# PROOF_EMAIL=playwright-proof@opsmantik.local
# PROOF_PASSWORD=ProofPass!12345

# Probe entegrasyon testi: npm run probe:token ile access token almak için
# PROBE_TEST_EMAIL=test@example.com
# PROBE_TEST_PASS=guvenli_sifre
# (Yoksa PROOF_EMAIL/PROOF_PASSWORD kullanılır)

# Watchtower GO W2 — Error tracking (Sentry / GlitchTip)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_DSN=          # optional server override
# OPSMANTIK_RELEASE=   # commit SHA for release tagging (server/edge)
# NEXT_PUBLIC_OPSMANTIK_RELEASE=  # optional, for client release tag
# SENTRY_ORG=          # optional, for source map upload
# SENTRY_PROJECT=      # optional
# SENTRY_AUTH_TOKEN=  # optional, keep secret

# Test-throw: set to 1 to make GET /api/watchtower/test-throw return 500 (for smoke)
# WATCHTOWER_TEST_THROW=1

# OCI Pull (Google Ads Script): API key for GET /api/oci/export-batch (x-api-key header)
# Generate a long random string; set the same value in Google Ads Script config.
# OCI_API_KEY=your-secret-key-here
# Optional: conversion action name sent to Google Ads (default: Sealed Lead)
# OCI_CONVERSION_NAME=Sealed Lead

# Production console URL (no trailing slash). Required for QStash to call /api/workers/ingest/* with an absolute URL.
# If unset locally, relative URLs break QStash enqueue; on Vercel, VERCEL_URL is used as fallback when this is empty.
# NEXT_PUBLIC_APP_URL=https://console.opsmantik.com

# Revenue Kernel: Redis (Upstash) for rate limit, usage cache, and billing metrics persistence.
# Required for /api/metrics to return cross-instance totals (ingest_source: redis).
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# Optional: per-site sync rate limit override when a site still hits 429 (default 500/min).
# Format: site_public_id:limit[,site_public_id2:limit2]
# OPSMANTIK_SYNC_RL_SITE_OVERRIDE=<site_public_id_hex>:500

# Production: enable all entitlements (sync, OCI, seal, export, etc.) for every site. Set to true in prod.
# OPSMANTIK_ENTITLEMENTS_FULL_ACCESS=true

# Cron auth: Bearer token for /api/cron/* (idempotency-cleanup, reconcile-usage, invoice-freeze, metrics, etc.)
# CRON_SECRET=your-cron-secret

# OCI session signing (Ed25519 or HMAC). Required in production. No empty fallback.
# OCI_SESSION_SECRET=your-session-secret
# VOID_LEDGER_SALT=your-merkle-salt  # Required in production for ledger hash verification; insecure fallback logs warning.

# Attribution Truth Engine refactor (Phase 0) — defaults preserve current behavior; no logic branches in PR1.
# TRUTH_SHADOW_WRITE_ENABLED=false
# When true, append-only rows are written to truth_evidence_ledger from sync + call-event workers (migration required).
# TRUTH_TYPED_EVIDENCE_ENABLED=false
# When true (with TRUTH_SHADOW_WRITE_ENABLED), truth_evidence_ledger.payload uses validated v2 envelope + schema_version phase2.
# TRUTH_ENGINE_CONSOLIDATED_ENABLED=false
# When true: PR4-A probe + PR4-B/C parity + PR4-E scoring-lineage parity (telemetry metrics; mismatch logs only; no persistence).
# TRUTH_INFERENCE_REGISTRY_ENABLED=false
# When true, records inference rows (sync attribution + call-event session match); requires migration truth_inference_runs.
# TRUTH_PROJECTION_READ_ENABLED=false
# When true, runs rebuild_call_projection + consistency probe after V2 funnel append (extra RPC load; staging/canary).
# IDENTITY_GRAPH_ENABLED=false
# When true, writes truth_identity_graph_edges (sha256 fingerprint → session); requires migration truth_identity_graph_edges.
# EXPLAINABILITY_API_ENABLED=false
# CONSENT_PROVENANCE_SHADOW_ENABLED=false
# When true, sync worker + call-event v2 run consent provenance shadow checks (metrics only; no enforcement).
# TRUTH_CANONICAL_LEDGER_SHADOW_ENABLED=false
# When true, append-only rows are written to truth_canonical_ledger from sync + call-event + funnel kernel (migration required; independent of TRUTH_SHADOW_WRITE_ENABLED).
# LEGACY_ENDPOINTS_ENABLED=true

# Daily Ad Spend webhook (POST /api/webhooks/google-spend). Google Ads Script sends this in x-opsmantik-webhook-secret or Bearer.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# GOOGLE_SPEND_WEBHOOK_SECRET=your-generated-secret
